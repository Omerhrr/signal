# Forex Probability Intelligence System - Environment Configuration
# MT5 Data Source Only
# 
# Copy this file to .env and customize as needed
# The system will use these settings across all components

# ============================================
# TRADING PAIRS CONFIGURATION
# ============================================
# Comma-separated list of pairs to monitor and trade
# These pairs will be used across the entire system:
# - Auto Scanner will scan these pairs
# - Market Radar will show these pairs
# - MT5 Windows Bridge will stream these pairs
#
# Common Forex Pairs:
#   EURUSD, GBPUSD, USDJPY, AUDUSD, NZDUSD, USDCAD, USDCHF
#   EURGBP, EURJPY, EURAUD, EURCAD, EURCHF
#   GBPJPY, GBPAUD, GBPCAD, GBPCHF
#   AUDJPY, CADJPY, CHFJPY
#   XAUUSD (Gold), XAGUSD (Silver)
#
# Example:
#   TRADING_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,EURJPY,GBPJPY,XAUUSD
TRADING_PAIRS=EURUSD,GBPUSD,USDJPY

# Default pair for single-pair analysis pages
DEFAULT_PAIR=EURUSD

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ============================================
# API CONFIGURATION
# ============================================
# FastAPI Backend (for internal services)
API_HOST=0.0.0.0
API_PORT=8000

# Flask Frontend (for web UI)
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ============================================
# REDIS CONFIGURATION (optional)
# ============================================
# Redis is used for caching and real-time data
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# RISK MANAGEMENT
# ============================================
# Maximum risk per trade (as decimal, 0.02 = 2%)
MAX_RISK_PER_TRADE=0.02

# Minimum confidence to generate signal (0.65 = 65%)
MIN_CONFIDENCE_THRESHOLD=0.65

# Maximum allowed spread in pips
MAX_SPREAD_PIPS=3.0

# Maximum volatility multiplier (pause trading if exceeded)
MAX_VOLATILITY_MULTIPLIER=2.5

# ============================================
# SIGNAL SETTINGS
# ============================================
# Signal expiry in minutes
SIGNAL_EXPIRY_MINUTES=30

# Minimum probability threshold for signals
MIN_PROBABILITY_THRESHOLD=0.55

# ============================================
# FAILURE DETECTION
# ============================================
# Instant failure threshold in pips
INSTANT_FAILURE_PIPS=15.0

# Slow failure duration in minutes
SLOW_FAILURE_MINUTES=20.0

# Fake breakout detection threshold
FAKE_BREAKOUT_THRESHOLD=0.3

# Volatility spike threshold
VOLATILITY_SPIKE_THRESHOLD=3.0

# ============================================
# MODEL TRAINING
# ============================================
# Day of week for model retraining (sunday, monday, etc.)
RETRAINING_DAY=sunday

# Hour for retraining (0-23)
RETRAINING_HOUR=2

# Minimum samples before retraining
MIN_SAMPLES_FOR_RETRAINING=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/forex_system.log

# ============================================
# MT5 WINDOWS BRIDGE SETTINGS
# ============================================
# These settings are used by mt5_windows_bridge.py
# The bridge reads the .env file for TRADING_PAIRS

# Interval between tick updates (seconds)
# BRIDGE_INTERVAL=1.0

# WSL IP address (find with 'hostname -I' in WSL)
# Pass via command line: --wsl-host <IP>
